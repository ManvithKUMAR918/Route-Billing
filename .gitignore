# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit .env files — set all secrets in Vercel's Environment Variables UI
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.production is safe to commit ONLY if it has no secrets (ours doesn't)

# ── Build outputs ─────────────────────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
backend/dist/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
